# Database
DATABASE_URL="postgres://user:password@host:5432/dbname"

# WordPress Integration
NEXT_PUBLIC_WP_URL="https://your-wordpress-site.com"
WP_API_SECRET="your_wp_api_secret"

# Authentication
AUTH_SECRET="your_auth_secret_32_chars_min"
NEXTAUTH_SECRET="your_auth_secret_32_chars_min"
NEXT_PUBLIC_APP_URL="https://your-app.com"
NEXTAUTH_URL="https://your-app.com"
AUTH_URL="https://your-app.com"

# AI Providers
GEMINI_API_KEY=""
REPLICATE_API_KEY=""
FAL_API_KEY=""
KIE_API_KEY=""
WAVESPEED_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""

# WooCommerce (optional, for product management)
WC_CONSUMER_KEY=""
WC_CONSUMER_SECRET=""
WP_PRO_PRODUCT_ID=""
WP_AGENCY_PRODUCT_ID=""

# ── Razorpay (Payment Gateway) ────────────────────────────────
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"

# Storage (optional)
R2_BUCKET_NAME=""
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_PUBLIC_URL=""

# Redis (optional, for rate limiting)
REDIS_URL=""
