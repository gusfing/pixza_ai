# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXTAUTH_URL=https://yourdomain.com
AUTH_URL=https://yourdomain.com

# ─── Auth Secrets (generate with: openssl rand -base64 32) ──
AUTH_SECRET=your_auth_secret_here
NEXTAUTH_SECRET=your_nextauth_secret_here

# ─── WordPress Backend ───────────────────────────────────────
# Your WordPress site URL (no trailing slash)
NEXT_PUBLIC_WP_URL=https://your-wordpress-site.com
# Secret for server-to-server WP calls (set same value in WP plugin settings)
WP_API_SECRET=your_wp_api_secret_here

# ─── Google OAuth (optional — for Google sign-in) ───────────
# Get credentials: https://console.cloud.google.com → APIs → Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── Database ────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── AI Providers ────────────────────────────────────────────
# Google Gemini — required for image generation + Veo video
# Get key: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Replicate — optional, for open-source models (SVD, TripoSR, etc.)
# Get key: https://replicate.com/account/api-tokens
REPLICATE_API_KEY=your_replicate_api_key_here

# fal.ai — optional, for FLUX, Kling, Wan, MiniMax, Trellis, etc.
# Get key: https://fal.ai/dashboard/keys
FAL_API_KEY=your_fal_api_key_here

# Kie.ai — optional, for Kie-specific models
# Get key: https://kie.ai
KIE_API_KEY=your_kie_api_key_here

# WaveSpeed — optional, for ultra-fast FLUX inference
# Get key: https://wavespeed.ai
WAVESPEED_API_KEY=your_wavespeed_api_key_here

# Cloudflare AI — optional, for free-tier image models
# Get credentials: https://dash.cloudflare.com → AI
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# ─── Storage (Cloudflare R2) ─────────────────────────────────
# Stores generated images/videos. Skip to serve base64 directly.
# Create bucket: https://dash.cloudflare.com → R2
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=pixza-generations
R2_PUBLIC_URL=https://cdn.yourdomain.com

# ─── Rate Limiting (Upstash Redis) ───────────────────────────
# Required in production — without this, rate limiting is disabled
# Free tier: https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ─── WooCommerce (optional — for subscription management) ────
WC_CONSUMER_KEY=your_wc_consumer_key
WC_CONSUMER_SECRET=your_wc_consumer_secret
WP_PRO_PRODUCT_ID=0
WP_AGENCY_PRODUCT_ID=0
